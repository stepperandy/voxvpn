{
  "name": "voxvpn-shield-agent",
  "version": "3.0.0",
  "description": "VoxVPN Shield Agent — VPN + DNS Protection",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev":        "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build":      "vite build",
    "build:win":  "electron-builder --win",
    "build:mac":  "electron-builder --mac",
    "build:linux":"electron-builder --linux"
  },
  "build": {
    "appId": "net.voxvpn.shield",
    "productName": "VoxShield",
    "copyright": "Copyright © 2026 VoxDigits Communications LLC",
    "directories": {
      "output": "../installer/voxshield/output"
    },
    "files": [
      "../dist/**/*",
      "main.js",
      "preload.js",
      "api.js",
      "*.jsx"
    ],
    "extraResources": [
      {
        "from": "../assets/configs",
        "to":   "configs",
        "filter": ["**/*.ovpn"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "../installer/windows/assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../installer/windows/assets/icon.ico",
      "uninstallerIcon": "../installer/windows/assets/icon.ico",
      "installerHeaderIcon": "../installer/windows/assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "../installer/voxshield/assets/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "../installer/voxshield/assets/entitlements.mac.plist",
      "entitlementsInherit": "../installer/voxshield/assets/entitlements.mac.plist"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "../installer/voxshield/assets/icon.png",
      "category": "Network"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  }
}